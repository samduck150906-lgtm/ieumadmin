# E2E 테스트용 환경 변수 예시 — 이 파일을 .env.test 로 복사한 뒤 값을 채우면
# test:all / test:all:web-only 실행 시 admin-flow 포함 전체 통과(3/3) 가능
# playwright.config.ts 가 .env.e2e 또는 .env.test 자동 로드
# 참고: docs/테스트_환경_설정.md

BASE_URL=http://localhost:3000
BASE_URL_LANDING=http://localhost:3001
BASE_URL_CUSTOMER=http://localhost:3003
BASE_URL_MOBILE_WEB=http://localhost:3002

# 어드민 로그인 — Supabase Authentication > Users에 해당 계정 생성·비밀번호 일치 확인
E2E_STAFF_EMAIL=admin@eum.co.kr
E2E_STAFF_PASSWORD=admin1234
