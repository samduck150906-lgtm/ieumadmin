# E2E 테스트용 환경 변수 예시 — 이 파일을 .env.e2e 로 복사한 뒤 값을 채우면
# 시나리오 B/C 등에서 매번 PowerShell에 환경 변수 설정하지 않아도 됩니다. (playwright.config.ts 가 자동 로드)
# 참고: docs/테스트_환경_설정.md

BASE_URL=http://localhost:3000
BASE_URL_LANDING=http://localhost:3001
BASE_URL_MOBILE_WEB=http://localhost:3002

# 어드민 로그인 — Supabase Authentication > Users에 admin@eum.co.kr 계정 생성·비밀번호 일치 확인
E2E_STAFF_EMAIL=admin@eum.co.kr
E2E_STAFF_PASSWORD=admin1234

# 모바일 앱 웹 로그인 (EXPO_PUBLIC_SAFE_MODE=false 빌드 필요)
E2E_APP_EMAIL=realtor@example.com
E2E_APP_PASSWORD=your-app-password

# 대시보드 앱 (선택)
# BASE_URL_DASHBOARD=http://localhost:5173

# 카카오 실제 로그인/회원가입 E2E (선택 — test:e2e:kakao 실행 시)
# E2E_KAKAO_EMAIL=your-kakao@email.com
# E2E_KAKAO_PASSWORD=your-kakao-password
