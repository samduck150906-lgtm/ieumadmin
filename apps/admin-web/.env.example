# ── Supabase OAuth (소셜 로그인) ─────────────────────────────
# Supabase 대시보드 → Authentication → Providers 에서 Provider별 Client ID/Secret 입력
# 발급처: 카카오(developers.kakao.com) | 구글(console.cloud.google.com) | 애플(developer.apple.com)
# SUPABASE_AUTH_KAKAO_CLIENT_SECRET=
# SUPABASE_AUTH_GOOGLE_CLIENT_ID=
# SUPABASE_AUTH_GOOGLE_CLIENT_SECRET=
# SUPABASE_AUTH_APPLE_CLIENT_ID=
# SUPABASE_AUTH_APPLE_CLIENT_SECRET=

# ── 사이트 URL ─────────────────────────────────────────────
