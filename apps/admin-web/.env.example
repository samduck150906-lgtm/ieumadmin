# ── 크론 API ───────────────────────────────────────────────
CRON_SECRET=dev-cron-secret-min-32-characters-long
# CRON_FAILURE_WEBHOOK=https://hooks.slack.com/services/xxx
# SLACK_WEBHOOK_CRON=https://hooks.slack.com/services/xxx

# ── 결제/이체 ──────────────────────────────────────────────
PAYMENT_PROVIDER=mock
PAYMENT_SESSION_SECRET=dev-change-me-immediately
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_placeholder
# TOSS_SECRET_KEY — 토스페이먼츠 개발자센터(https://developers.tosspayments.com) → API 키 → 시크릿 키 (1원 계좌 인증·결제 승인용)
TOSS_SECRET_KEY=test_sk_placeholder

# ── 알리고 (SMS + 알림톡) ──────────────────────────────────
# https://smartsms.aligo.in 에서 발급
ALIGO_API_KEY=your-api-key
ALIGO_USER_ID=your-user-id
ALIGO_SENDER=02-0000-0000
KAKAO_SENDER_KEY=your-sender-key

# ── 이메일 (SMTP) ─────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@ieum.in

# ── 파트너 신청 알림 SMS ────────────────────────────────────
# ADMIN_NOTIFY_PHONES=010-0000-0000,010-1111-1111

