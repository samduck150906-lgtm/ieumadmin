{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": ["icn1"],
  "crons": [
    { "path": "/api/cron/check-auto-complete", "schedule": "0 3 * * *" },
    { "path": "/api/cron/partner-reminders", "schedule": "0 3,8 * * *" },
    { "path": "/api/cron/mark-stalled", "schedule": "0 6 * * *" },
    { "path": "/api/cron/unread-reassign", "schedule": "*/15 * * * *" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
